<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Le Comptoir - Spécialiste des Filtres</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', sans-serif;
            color: #333;
        }

        /* NAVBAR */
        nav {
            background: #1a1a2e;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        nav .logo {
            color: #e94560;
            font-size: 24px;
            font-weight: bold;
            letter-spacing: 2px;
        }
        nav ul {
            list-style: none;
            display: flex;
            gap: 25px;
        }
        nav ul a {
            color: white;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s;
        }
        nav ul a:hover { color: #e94560; }

        /* HERO */
        .hero {
            background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            color: white;
            text-align: center;
            padding: 100px 20px;
        }
        .hero h1 {
            font-size: 52px;
            margin-bottom: 15px;
            color: #e94560;
        }
        .hero p {
            font-size: 20px;
            margin-bottom: 30px;
            opacity: 0.9;
        }
        .hero .btn {
            background: #e94560;
            color: white;
            padding: 15px 40px;
            border-radius: 30px;
            text-decoration: none;
            font-size: 16px;
            transition: transform 0.3s;
        }
        .hero .btn:hover { transform: scale(1.05); }

        /* STATS */
        .stats {
            background: #e94560;
            display: flex;
            justify-content: space-around;
            padding: 40px 20px;
            flex-wrap: wrap;
        }
        .stat {
            text-align: center;
            color: white;
        }
        .stat h2 { font-size: 42px; font-weight: bold; }
        .stat p { font-size: 14px; opacity: 0.9; }

        /* SECTIONS */
        section {
            padding: 70px 30px;
        }
        section h2 {
            text-align: center;
            font-size: 36px;
            margin-bottom: 10px;
            color: #1a1a2e;
        }
        .underline {
            width: 60px;
            height: 4px;
            background: #e94560;
            margin: 0 auto 50px;
            border-radius: 2px;
        }

        /* PRODUITS */
        .produits { background: #f9f9f9; }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }
        .card:hover { transform: translateY(-8px); }
        .card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }
        .card-body {
            padding: 20px;
        }
        .card-body h3 {
            color: #1a1a2e;
            margin-bottom: 8px;
            font-size: 18px;
        }
        .card-body p {
            color: #666;
            font-size: 14px;
            line-height: 1.6;
        }
        .badge {
            display: inline-block;
            background: #e94560;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            margin-top: 10px;
        }

        /* HISTORIQUE */
        .historique { background: white; }
        .timeline {
            max-width: 800px;
            margin: 0 auto;
            position: relative;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 3px;
            background: #e94560;
            transform: translateX(-50%);
        }
        .timeline-item {
            display: flex;
            justify-content: flex-end;
            padding-right: calc(50% + 30px);
            margin-bottom: 40px;
            position: relative;
        }
        .timeline-item:nth-child(even) {
            justify-content: flex-start;
            padding-right: 0;
            padding-left: calc(50% + 30px);
        }
        .timeline-content {
            background: #f9f9f9;
            border-radius: 10px;
            padding: 20px;
            max-width: 300px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.1);
            border-left: 4px solid #e94560;
        }
        .timeline-content h3 {
            color: #e94560;
            font-size: 22px;
            margin-bottom: 5px;
        }
        .timeline-content p {
            color: #555;
            font-size: 14px;
        }

        /* FOURNISSEURS */
        .fournisseurs { background: #f9f9f9; }
        .fournisseurs-grid {
            display: flex;
            justify-content: center;
            gap: 50px;
            flex-wrap: wrap;
            max-width: 900px;
            margin: 0 auto;
        }
        .fournisseur-card {
            background: white;
            border-radius: 15px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 5px 25px rgba(0,0,0,0.1);
            width: 280px;
            transition: transform 0.3s;
        }
        .fournisseur-card:hover { transform: scale(1.05); }
        .fournisseur-card .logo-text {
            font-size: 36px;
            font-weight: bold;
            color: #1a1a2e;
            margin-bottom: 15px;
        }
        .fournisseur-card .logo-text span { color: #e94560; }
        .fournisseur-card p {
            color: #666;
            font-size: 14px;
            line-height: 1.6;
        }

        /* CONTACT */
        .contact { background: #1a1a2e; color: white; text-align: center; }
        .contact h2 { color: white; }
        .contact-info {
            display: flex;
            justify-content: center;
            gap: 50px;
            flex-wrap: wrap;
            margin-top: 40px;
        }
        .contact-item {
            background: rgba(255,255,255,0.1);
            padding: 30px;
            border-radius: 12px;
            min-width: 200px;
        }
        .contact-item .icon { font-size: 36px; margin-bottom: 10px; }
        .contact-item h3 { color: #e94560; margin-bottom: 8px; }
        .contact-item p { opacity: 0.8; font-size: 14px; }

        /* FOOTER */
        footer {
            background: #0d0d1a;
            color: white;
            text-align: center;
            padding: 20px;
            font-size: 13px;
            opacity: 0.7;
        }

        @media (max-width: 600px) {
            .hero h1 { font-size: 32px; }
            nav ul { display: none; }
            .timeline::before { left: 20px; }
            .timeline-item, .timeline-item:nth-child(even) {
                padding: 0 0 0 50px;
                justify-content: flex-start;
            }
        }
    </style>
</head>
